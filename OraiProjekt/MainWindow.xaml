<Window x:Class="OraiProjekt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zenelejátszó" Height="400" Width="300">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- Borítókép -->
        <Image x:Name="albumImage" Width="200" Height="200" Margin="10"/>

        <!-- Lejátszó -->
        <MediaElement x:Name="player" LoadedBehavior="Manual"/>

        <!-- Gomb -->
        <Button Content="Play" Click="Play_Click" Margin="10"/>

    </StackPanel>
</Window>